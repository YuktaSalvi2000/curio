{
  "compilerOptions": {
    "target": "es2021",
    "module": "esnext",
    "moduleResolution": "bundler",

    "jsx": "react-jsx",

    "allowJs": true,
    "strict": true,

    "esModuleInterop": true,
    "sourceMap": true,

    "rootDir": "./src",
    "outDir": "./dist",

    "types": ["node"],

    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}